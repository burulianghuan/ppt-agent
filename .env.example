# 中转 API（OpenAI 兼容协议）
LLM_BASE_URL=https://your-proxy.example.com/v1
LLM_API_KEY=

# 若 Grok / Gemini 分属不同 Key（推荐分开写）
GROK_BASE_URL=https://your-proxy.example.com/v1
GROK_API_KEY=sk-your-grok-key
GROK_MODEL=grok-4.20-multi-agent-xhigh

GEMINI_BASE_URL=https://your-proxy.example.com/v1
GEMINI_API_KEY=sk-your-gemini-key
GEMINI_MODEL=gemini-3.1-pro
# GEMINI_DESIGN_MODEL=gemini-3.5-flash

HOST=127.0.0.1
PORT=8787
OUTPUT_DIR=outputs
LLM_TIMEOUT=300
